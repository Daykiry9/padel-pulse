# Template — copy to `keystore.properties` (gitignored) and fill from your
# secure storage (SSD cifrado / password manager). NEVER commit this file
# with real passwords.
#
# storeFile: relative to this file (apps/web/android/app/)
# keyAlias: must match the alias used when generating the keystore
# *Password: same value as storePassword (we used Enter at keytool prompt)

storeFile=padelking-release.keystore
storePassword=REPLACE_WITH_REAL_PASSWORD
keyAlias=padelking
keyPassword=REPLACE_WITH_REAL_PASSWORD
