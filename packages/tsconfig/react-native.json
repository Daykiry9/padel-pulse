{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native (Expo)",
  "extends": "./base.json",
  "compilerOptions": {
    "allowJs": true,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-native",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "target": "ES2022",
    "types": ["nativewind/types"]
  }
}
